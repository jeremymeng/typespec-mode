;; -*- mode: emacs-lisp; lexical-binding: t -*-

(eldev-use-package-archive 'gnu-elpa)
(eldev-use-package-archive 'nongnu-elpa)
(eldev-use-package-archive 'melpa-stable)

;; Emacs on Windows CI runners (and many local Windows installs) cannot
;; reliably verify package signatures from GNU/NonGNU ELPA because no
;; usable ``gpg`` executable is on PATH.  This causes
;; ``bad-signature'' errors during ``eldev`` dependency install.
;; Linux and macOS keep the default (signed) behavior.
(when (eq system-type 'windows-nt)
  (setq package-check-signature nil))

(eldev-add-extra-dependencies 'test 'yasnippet)
(eldev-add-extra-dependencies 'test 'flycheck)

;; Bundle the snippets directory into the installable package so that
;; `typespec-snippets-directory' (which is computed from the
;; `.elc' location at load time) actually has a `snippets/'
;; sibling after eldev's packaged-mode install.
(setf eldev-files-to-package
      `(:or ,eldev-files-to-package "./snippets" "./snippets/**"))

(setf eldev-test-fileset '("./test/*.el"))
